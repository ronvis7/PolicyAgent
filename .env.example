# =============================================================================
# PolicyManus 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并修改为自己的配置
# cp .env.example .env

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------

# Nginx 对外访问端口（使用不常见端口避免冲突）
NGINX_PORT=8888

# PostgreSQL 数据库密码（建议修改为强密码）
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_USER=postgres
POSTGRES_DB=policy_manus

# Redis 密码（如无密码请留空）
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT 认证配置（多租户系统，必须修改 JWT_SECRET_KEY 为强随机值）
# -----------------------------------------------------------------------------

# JWT 签名密钥（生产环境务必改为强随机值，例如: openssl rand -hex 32）
JWT_SECRET_KEY=change-me-to-a-strong-random-secret

# JWT 签名算法
JWT_ALGORITHM=HS256

# access 令牌有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# refresh 令牌有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=14

# -----------------------------------------------------------------------------
# 腾讯云 COS 配置（必须配置）
# -----------------------------------------------------------------------------

# 腾讯云 SecretId（从腾讯云控制台获取，以 AKID 开头）
COS_SECRET_ID=your_cos_secret_id_here

# 腾讯云 SecretKey（从腾讯云控制台获取）
COS_SECRET_KEY=your_cos_secret_key_here

# COS 存储桶地域（如：ap-beijing, ap-shanghai, ap-guangzhou 等）
COS_REGION=ap-chongqing

# COS 存储桶名称
COS_BUCKET=your-bucket-name-xxxxxxxx

# COS 访问协议（https 或 http）
COS_SCHEME=https

# COS 自定义域名（如使用自定义域名，请填写；否则留空）
COS_DOMAIN=

# -----------------------------------------------------------------------------
# 沙箱配置
# -----------------------------------------------------------------------------

# 沙箱镜像名（必须与 docker-compose 构建出的 policy-sandbox 镜像一致）
SANDBOX_IMAGE=policy-sandbox

# 动态创建的沙箱容器要加入的网络（必须与主网络 policy-network 一致，否则 API 连不上沙箱）
SANDBOX_NETWORK=policy-network

# 沙箱容器名前缀
SANDBOX_NAME_PREFIX=policy-sandbox

# 沙箱容器存活时间（分钟）
SANDBOX_TTL_MINUTES=60

# Chrome 浏览器额外启动参数（可选）
# SANDBOX_CHROME_ARGS=--proxy-server=http://proxy.example.com:8080

# 代理配置（如需要使用代理）
# SANDBOX_HTTPS_PROXY=http://proxy.example.com:8080
# SANDBOX_HTTP_PROXY=http://proxy.example.com:8080
# SANDBOX_NO_PROXY=localhost,127.0.0.1
